{
    "name": "site",
    "version": "0.1.0",
    "packageManager": "yarn@4.15.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "npx serve@latest out",
        "postinstall": "next telemetry disable",
        "lint": "eslint src --color",
